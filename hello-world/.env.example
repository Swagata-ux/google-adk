# ============================================
# Hello World Agent - Environment Variables
# ============================================
#
# INSTRUCTIONS:
# 1. Copy this file to .env: cp .env.example .env
# 2. Replace the placeholder with your actual Google API key
# 3. Never commit the .env file to version control
#
# Get your API key from: https://aistudio.google.com/apikey
# ============================================

# Use Vertex AI (0 = use Google AI Studio API, 1 = use Vertex AI)
GOOGLE_GENAI_USE_VERTEXAI=0

# Your Google GenAI API Key (replace with actual key)
GOOGLE_API_KEY=your_api_key_here
